{
  "name": "@truss-harness/cli",
  "version": "0.1.0",
  "description": "Command-line client and runtime service for Truss.",
  "type": "module",
  "exports": {
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "bin": {
    "truss-cli": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc -b",
    "postinstall": "node scripts/postinstall.mjs",
    "prepack": "node ../../scripts/clean-publish-tests.mjs",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md",
    "logo.png"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/truss-harness/truss-harness.git"
  },
  "bugs": {
    "url": "https://github.com/truss-harness/truss-harness/issues"
  },
  "homepage": "https://github.com/truss-harness/truss-harness#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "ollama",
    "lm-studio",
    "local-first"
  ],
  "dependencies": {
    "@truss-harness/branding": "0.1.0",
    "@truss-harness/provider-openai-compatible": "0.1.0",
    "@truss-harness/runtime": "0.1.0"
  }
}
