{
  "name": "@truss-harness/desktop",
  "version": "0.1.0",
  "description": "Standalone desktop client for the Truss runtime.",
  "author": "Truss Contributors",
  "type": "module",
  "main": "./dist/main.cjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild ./dist/main.js --bundle --platform=node --format=cjs --external:electron --outfile=./dist/main.cjs && esbuild ./dist/preload.js --bundle --platform=node --format=cjs --external:electron --outfile=./dist/preload.cjs && node ./scripts/copy-static.mjs",
    "dev": "npm run build && node ./scripts/start-electron.mjs",
    "start": "node ./scripts/start-electron.mjs",
    "package": "npm run build && electron-builder",
    "package:win:x64": "npm run build && electron-builder --win nsis --x64",
    "package:win:arm64": "npm run build && electron-builder --win nsis --arm64",
    "package:linux:x64": "npm run build && electron-builder --linux AppImage deb rpm pacman --x64",
    "package:linux:arm64": "npm run build && electron-builder --linux AppImage deb rpm pacman --arm64"
  },
  "build": {
    "appId": "com.truss-harness.desktop",
    "productName": "Truss",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "win": {
      "icon": "./assets/brand-logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "icon": "./assets/brand-logo.png",
      "category": "Development",
      "synopsis": "Local-first coding agent workspace",
      "description": "Desktop workspace for local coding models with chat, tools, Git, terminal, editor, and approval controls.",
      "vendor": "Truss Contributors",
      "maintainer": "Truss Contributors",
      "executableName": "truss-harness",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "pacman",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/truss-harness/truss-harness.git"
  },
  "dependencies": {
    "@truss-harness/branding": "0.1.0",
    "@truss-harness/cli": "0.1.0",
    "@truss-harness/provider-openai-compatible": "0.1.0",
    "@truss-harness/runtime": "0.1.0"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0"
  },
  "bugs": {
    "url": "https://github.com/truss-harness/truss-harness/issues"
  },
  "homepage": "https://github.com/truss-harness/truss-harness#readme"
}
