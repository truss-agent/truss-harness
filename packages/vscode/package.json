{
  "name": "truss-harness-vscode",
  "displayName": "Truss",
  "description": "VS Code client for the Truss runtime.",
  "version": "0.1.8",
  "publisher": "truss-harness",
  "repository": {
    "type": "git",
    "url": "https://github.com/truss-agent/truss-harness"
  },
  "bugs": {
    "url": "https://github.com/truss-agent/truss-harness/issues"
  },
  "homepage": "https://github.com/truss-agent/truss-harness#readme",
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:trussHarness.chat",
    "onCommand:trussHarness.openChat",
    "onCommand:trussHarness.connectTrussGo",
    "onCommand:trussHarness.configureByokProvider",
    "onCommand:trussHarness.removeByokCredential",
    "onCommand:trussHarness.generateCommitMessage",
    "onCommand:trussHarness.initializeWorkspace",
    "onCommand:trussHarness.updateWorkspaceMemory",
    "onCommand:trussHarness.showWorkspaceStatus",
    "onCommand:trussHarness.clearWorkspaceMemory"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trussHarness",
          "title": "Truss",
          "icon": "media/truss-harness.svg"
        }
      ]
    },
    "views": {
      "trussHarness": [
        {
          "type": "webview",
          "id": "trussHarness.chat",
          "name": "Chat",
          "webviewOptions": {
            "retainContextWhenHidden": true
          }
        }
      ]
    },
    "commands": [
      {
        "command": "trussHarness.openChat",
        "title": "Truss: Open Chat"
      },
      {
        "command": "trussHarness.connectTrussGo",
        "title": "Truss: Connect Truss Go"
      },
      {
        "command": "trussHarness.configureByokProvider",
        "title": "Truss: Configure BYOK Provider"
      },
      {
        "command": "trussHarness.removeByokCredential",
        "title": "Truss: Remove BYOK Provider Key"
      },
      {
        "command": "trussHarness.generateCommitMessage",
        "title": "Truss: Generate Commit Message",
        "icon": "media/truss-harness.svg"
      },
      {
        "command": "trussHarness.initializeWorkspace",
        "title": "Truss: Initialize Workspace Instructions"
      },
      {
        "command": "trussHarness.updateWorkspaceMemory",
        "title": "Truss: Update Workspace Memory"
      },
      {
        "command": "trussHarness.showWorkspaceStatus",
        "title": "Truss: Show Workspace Status"
      },
      {
        "command": "trussHarness.clearWorkspaceMemory",
        "title": "Truss: Clear Workspace Memory"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "trussHarness.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation@10"
        }
      ]
    },
    "configuration": {
      "title": "Truss",
      "properties": {
        "trussHarness.command": {
          "type": "string",
          "default": "",
          "description": "Optional path to an external Truss CLI executable. Leave empty to use the service bundled with the extension."
        },
        "trussHarness.model": {
          "type": "string",
          "description": "Model identifier exposed by the configured OpenAI-compatible server."
        },
        "trussHarness.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "Base URL of an OpenAI-compatible API server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p . && npm run bundle",
    "bundle": "node ../../scripts/prepare-vscode-bundle.mjs && esbuild ./src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.cjs && esbuild ../cli/src/bin.ts --bundle --platform=node --format=cjs --outfile=dist/truss-service.cjs",
    "package": "node ../../scripts/sync-brand-assets.mjs && npm run build && vsce package --no-dependencies",
    "prepublishOnly": "npm run package"
  },
  "dependencies": {
    "@truss-harness/gateway": "0.1.2",
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4",
    "@truss-harness/branding": "0.1.0",
    "@truss-harness/provider-openai-compatible": "0.1.2",
    "@truss-harness/runtime": "0.1.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.25.0"
  },
  "icon": "media/truss-harness.png"
}
