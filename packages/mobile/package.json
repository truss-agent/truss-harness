{
  "name": "@truss-harness/mobile",
  "version": "0.1.1",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "android:release:device": "expo run:android --device --variant release",
    "android:apk:local": "npx eas-cli build --local --platform android --profile preview",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~54.0.36",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "17.0.10",
    "expo-secure-store": "15.0.8",
    "react": "19.1.4",
    "react-native": "0.81.6"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "typescript": "^5.7.2"
  }
}
